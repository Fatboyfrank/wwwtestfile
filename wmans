    // ============ PROPERTY TOOLS ============
    
    function searchAddress() {
      const address = document.getElementById('address-input').value;
      if (!address) return;
      
      searchCount++;
      
      const encoded = encodeURIComponent(address);
      
      fetch(`https://api.mapbox.com/geocoding/v5/mapbox.places/${encoded}.json?access_token=${mapboxgl.accessToken}`)
        .then(r => r.json())
        .then(data => {
          if (data.features && data.features.length > 0) {
            const coords = data.features[0].center;
            map.flyTo({ center: coords, zoom: 17 });
            addMarker({ lng: coords[0], lat: coords[1] }, address, 'house');
            showHouseInfo({ lng: coords[0], lat: coords[1] }, { address });
          }
        });
      
      window.open(`https://www.google.com/search?q="${encoded}"`, '_blank');
      window.open(`https://www.zillow.com/homes/${encoded}_rb/`, '_blank');
      window.open(`https://www.redfin.com/search?query=${encoded}`, '_blank');
    }
    
    function findNeighbors() {
      if (!currentHouse) return;
      const coords = currentHouse.coords;
      
      for (let i = 0; i < 8; i++) {
        const angle = (i / 8) * Math.PI * 2;
        const dist = 0.001;
        const newLng = coords.lng + Math.cos(angle) * dist;
        const newLat = coords.lat + Math.sin(angle) * dist;
        addMarker({ lng: newLng, lat: newLat }, `Neighbor ${i + 1}`, 'house');
      }
    }
    
    function streetView() {
      if (!currentHouse) return;
      const coords = currentHouse.coords;
      window.open(`https://www.google.com/maps/@?api=1&map_action=pano&viewpoint=${coords.lat},${coords.lng}`, '_blank');
    }
    
