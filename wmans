        // Bulk Operations
        function startBulk() {
            bulkRunning = true;
            bulkPaused = false;
            showToast('Bulk operation started', 'success');
            
            let progress = 0;
            const interval = setInterval(() => {
                if (!bulkRunning || bulkPaused) {
                    clearInterval(interval);
                    return;
                }
                progress += 5;
                document.getElementById('bulkProgress').style.width = progress + '%';
                document.getElementById('bulkSuccess').textContent = Math.floor(progress / 2);
                
                if (progress >= 100) {
                    clearInterval(interval);
                    bulkRunning = false;
                    showToast('Bulk operation complete', 'success');
                }
            }, 200);
        }

        function pauseBulk() {
            bulkPaused = !bulkPaused;
            showToast(bulkPaused ? 'Bulk operation paused' : 'Bulk operation resumed', 'success');
        }

        function stopBulk() {
            bulkRunning = false;
            showToast('Bulk operation stopped', 'error');
        }

        function exportBulk() {
            showToast('Exporting results...', 'success');
        }

        // Quick search
        function quickSearch() {
            const query = document.getElementById('quickSearch').value;
            if (!query) return showToast('Enter search query', 'error');
            showToast(`Searching all sources for: ${query}`, 'success');
        }

        function locateMe() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(position => {
                    const { latitude, longitude } = position.coords;
                    const map = maps['mainMap'];
                    if (map) {
                        map.setView([latitude, longitude], 15);
                        L.marker([latitude, longitude]).addTo(map)
                            .bindPopup('Your Location')
                            .openPopup();
                    }
                    showToast('Location found', 'success');
                }, () => showToast('Could not get location', 'error'));
            }
        }
