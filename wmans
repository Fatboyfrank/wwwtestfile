                ]
            };

            if (isEmail) {
                base.person = {
                    name: query.split('@')[0].replace(/[._]/g, ' ').replace(/\b\w/g, l => l.toUpperCase()),
                    email: query,
                    aliases: [query.replace(/@/, '+old@'), query.replace(/@gmail/, '@yahoo')],
                    addresses: ['123 Main St, Los Angeles, CA 90210', '456 Oak Ave, Santa Monica, CA 90405'],
                    phones: ['(310) 555-' + Math.floor(1000 + Math.random() * 8999), '(323) 555-' + Math.floor(1000 + Math.random() * 8999)],
                    breaches: ['LinkedIn 2021', 'Adobe 2013', 'Dropbox 2012'],
                    socialProfiles: {
                        twitter: '@' + query.split('@')[0],
                        instagram: query.split('@')[0],
                        linkedin: 'linkedin.com/in/' + query.split('@')[0]
                    }
                };
            } else if (isPhone) {
                base.phone = {
                    number: query,
                    carrier: ['Verizon', 'AT&T', 'T-Mobile'][Math.floor(Math.random() * 3)],
                    type: 'Mobile',
                    location: 'Los Angeles, CA',
                    registeredTo: 'John M. Doe',
                    previousOwners: 2,
                    portHistory: ['AT&T (2018-2020)', 'Verizon (2020-Present)']
                };
            } else if (isIP) {
                base.ip = {
                    address: query,
                    isp: 'Comcast Cable Communications, LLC',
                    org: 'Xfinity',
                    country: 'United States',
                    region: 'California',
                    city: 'Los Angeles',
                    lat: 34.0522,
