        // Geocoding
        async function forwardGeocode() {
            const address = [
                document.getElementById('fwdAddress').value,
                document.getElementById('fwdCity').value,
                document.getElementById('fwdState').value,
                document.getElementById('fwdZip').value
            ].filter(Boolean).join(', ');
            
            if (!address) return showToast('Enter address', 'error');
            
            try {
                // Using Nominatim (free OpenStreetMap geocoding)
                const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`);
                const data = await response.json();
                
                if (data && data.length > 0) {
                    const result = data[0];
                    const resultDiv = document.getElementById('geocodeResult');
                    resultDiv.classList.remove('hidden');
                    resultDiv.innerHTML = `
                        <div style="color: var(--neon-green);">Location found:</div>
                        <div class="coords" style="font-size: 1.2rem; margin: 10px 0;">${result.lat}, ${result.lon}</div>
                        <div><strong>Display Name:</strong> ${result.display_name}</div>
                        <div><strong>Type:</strong> ${result.type}</div>
                        <div><strong>Class:</strong> ${result.class}</div>
                        <div><strong>Importance:</strong> ${result.importance}</div>
                    `;
                    
                    const map = initMap('addressMap');
                    L.marker([result.lat, result.lon]).addTo(map)
                        .bindPopup(result.display_name)
                        .openPopup();
                    map.setView([result.lat, result.lon], 16);
                    
                    showToast('Address geocoded', 'success');
                } else {
                    showToast('Address not found', 'error');
                }
            } catch (error) {
                showToast('Geocoding error: ' + error.message, 'error');
