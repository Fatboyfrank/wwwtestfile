<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OSINT Master Pro - Complete Intelligence Suite</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --neon: #00f0ff;
            --neon-purple: #b026ff;
            --neon-green: #00ff88;
            --neon-red: #ff4444;
            --neon-orange: #ff8800;
            --bg: #0a0a0f;
            --card: #12121a;
            --card-hover: #1a1a25;
            --border: #2a2a3a;
            --text: #e0e0e0;
            --text-dim: #888;
        }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }
        
        .app-container { display: flex; min-height: 100vh; }
        .sidebar {
            width: 280px;
            background: var(--card);
            border-right: 1px solid var(--border);
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
            transition: transform 0.3s;
        }
        .sidebar.collapsed { transform: translateX(-100%); }
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 20px;
            min-height: 100vh;
        }
        
        .app-header {
            background: linear-gradient(135deg, var(--card) 0%, var(--card-hover) 100%);
            padding: 20px;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .app-title {
            font-size: 1.8rem;
            background: linear-gradient(90deg, var(--neon), var(--neon-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }
        
        .nav-section {
            padding: 15px 20px;
            color: var(--text-dim);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            cursor: pointer;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            position: relative;
        }
        .nav-item:hover, .nav-item.active {
            background: rgba(0, 240, 255, 0.1);
            border-left-color: var(--neon);
            color: var(--neon);
        }
        .nav-item i { width: 20px; text-align: center; }
        .nav-badge {
            position: absolute;
            right: 15px;
            background: var(--neon-red);
            color: #fff;
            font-size: 0.65rem;
            padding: 2px 6px;
            border-radius: 10px;
        }
        
        .smart-search {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .search-input-wrapper {
            display: flex;
            gap: 10px;
            align-items: center;
        }
        .smart-input {
            flex: 1;
            padding: 15px 20px;
            background: var(--bg);
            border: 2px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: 1rem;
            transition: all 0.3s;
        }
        .smart-input:focus {
            outline: none;
            border-color: var(--neon);
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.2);
        }
        .smart-input::placeholder { color: var(--text-dim); }
        
        .detected-type {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(0, 240, 255, 0.1);
            border: 1px solid var(--neon);
            border-radius: 20px;
            font-size: 0.85rem;
            color: var(--neon);
            margin-top: 10px;
        }
        
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .card-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #fff;
        }
        
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--neon), var(--neon-purple));
            color: #000;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0, 240, 255, 0.4);
        }
        .btn-secondary {
            background: var(--border);
            color: var(--text);
        }
        .btn-secondary:hover { background: #3a3a4a; }
        .btn-success {
            background: var(--neon-green);
            color: #000;
        }
        .btn-danger {
            background: var(--neon-red);
            color: #fff;
        }
        .btn-orange {
            background: var(--neon-orange);
            color: #000;
        }
        .btn-sm { padding: 8px 16px; font-size: 0.85rem; }
        .btn-lg { padding: 15px 30px; font-size: 1rem; }
        
        .result-grid {
            display: grid;
            gap: 15px;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        }
        .result-item {
            background: var(--card-hover);
            border-radius: 8px;
            padding: 15px;
            border-left: 3px solid var(--neon);
        }
        .result-label {
            color: var(--text-dim);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }
        .result-value {
            color: #fff;
            font-size: 1rem;
            font-weight: 500;
        }
        .result-value.highlight {
            color: var(--neon);
            font-family: monospace;
        }
        
        .map-container {
            height: 400px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid var(--border);
        }
        
        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .status-online {
            background: rgba(0, 255, 136, 0.2);
            color: var(--neon-green);
        }
        .status-offline {
            background: rgba(255, 68, 68, 0.2);
            color: var(--neon-red);
        }
        .status-loading {
            background: rgba(255, 136, 0, 0.2);
            color: #ff8800;
        }
        
        .pulse-loader {
            width: 10px;
            height: 10px;
            background: currentColor;
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        .data-table th, .data-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }
        .data-table th {
            color: var(--neon);
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
        }
        .data-table tr:hover {
            background: var(--card-hover);
        }
        
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin-top: 15px;
        }
        .quick-action-btn {
            padding: 15px;
            background: var(--card-hover);
            border: 1px solid var(--border);
            border-radius: 8px;
            cursor: pointer;
            text-align: center;
            transition: all 0.2s;
        }
        .quick-action-btn:hover {
            border-color: var(--neon);
            background: rgba(0, 240, 255, 0.1);
        }
        .quick-action-btn i {
            font-size: 1.5rem;
            color: var(--neon);
            margin-bottom: 8px;
            display: block;
        }
        .quick-action-btn span {
            font-size: 0.85rem;
            color: var(--text);
        }
        
        .toast-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .toast {
            background: var(--card);
            border: 1px solid var(--border);
            border-left: 3px solid var(--neon);
            padding: 15px 20px;
            border-radius: 8px;
            min-width: 300px;
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        .hidden { display: none !important; }
        
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; }
        }
        
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--neon);
        }

        /* Code editor style for payloads */
        .code-editor {
            background: #0d0d12;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
            color: #00ff00;
            min-height: 200px;
            white-space: pre-wrap;
            overflow-x: auto;
        }

        .payload-template {
            background: var(--card-hover);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .payload-template:hover {
            border-color: var(--neon-green);
            background: rgba(0, 255, 136, 0.1);
        }
        .payload-template.selected {
            border-color: var(--neon-green);
            background: rgba(0, 255, 136, 0.2);
        }

        .progress-bar {
            width: 100%;
            height: 20px;
            background: var(--bg);
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid var(--border);
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--neon), var(--neon-green));
            transition: width 0.3s;
        }

        .terminal-output {
            background: #000;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            font-family: monospace;
            font-size: 0.85rem;
            color: #0f0;
            max-height: 300px;
            overflow-y: auto;
        }
        .terminal-line {
            margin-bottom: 5px;
        }
        .terminal-line.error { color: #f00; }
        .terminal-line.warn { color: #ff0; }
        .terminal-line.info { color: #0f0; }
        .terminal-line.success { color: #0ff; }

        .checkbox-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin-top: 10px;
        }
        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px;
            background: var(--card-hover);
            border-radius: 6px;
            cursor: pointer;
        }
        .checkbox-item input[type="checkbox"] {
            accent-color: var(--neon);
        }

        .tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 15px;
            border-bottom: 2px solid var(--border);
        }
        .tab {
            padding: 10px 20px;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
        }
        .tab:hover { color: var(--neon); }
        .tab.active {
            color: var(--neon);
            border-bottom-color: var(--neon);
        }

        .encryption-status {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 15px;
            background: rgba(0, 255, 136, 0.1);
            border: 1px solid var(--neon-green);
            border-radius: 8px;
            margin-bottom: 15px;
        }
        .encryption-status i {
            color: var(--neon-green);
            font-size: 1.2rem;
        }

        .target-list {
            max-height: 200px;
            overflow-y: auto;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px;
        }
        .target-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px;
            border-bottom: 1px solid var(--border);
        }
        .target-item:last-child { border-bottom: none; }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }
        .stat-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }
        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--neon);
        }
        .stat-label {
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <nav class="sidebar">
            <div class="app-header">
                <div class="app-title"><i class="fas fa-satellite-dish"></i> OSINT Master</div>
                <div style="color: var(--text-dim); font-size: 0.75rem; margin-top: 5px;">Complete Intelligence Suite</div>
            </div>
            
            <div class="nav-section">Main</div>
            <div class="nav-item active" onclick="showSection('dashboard')">
                <i class="fas fa-home"></i> Dashboard
            </div>
            <div class="nav-item" onclick="showSection('universal')">
                <i class="fas fa-search"></i> Universal Search
                <span class="nav-badge">NEW</span>
            </div>
            
            <div class="nav-section">Intelligence</div>
            <div class="nav-item" onclick="showSection('person')">
                <i class="fas fa-user"></i> Person Lookup
            </div>
            <div class="nav-item" onclick="showSection('phone')">
                <i class="fas fa-phone"></i> Phone Intel
            </div>
            <div class="nav-item" onclick="showSection('email')">
                <i class="fas fa-envelope"></i> Email Analysis
            </div>
            <div class="nav-item" onclick="showSection('address')">
                <i class="fas fa-map-marker-alt"></i> Address & Property
            </div>
            <div class="nav-item" onclick="showSection('vehicle')">
                <i class="fas fa-car"></i> Vehicle Tracking
            </div>
            
            <div class="nav-section">Digital</div>
            <div class="nav-item" onclick="showSection('social')">
                <i class="fas fa-users"></i> Social Media
            </div>
            <div class="nav-item" onclick="showSection('breach')">
                <i class="fas fa-shield-alt"></i> Breach Database
            </div>
            <div class="nav-item" onclick="showSection('domain')">
                <i class="fas fa-globe"></i> Domain Intel
            </div>
            <div class="nav-item" onclick="showSection('image')">
                <i class="fas fa-image"></i> Image Analysis
            </div>
            
            <div class="nav-section">Advanced</div>
            <div class="nav-item" onclick="showSection('badusb')">
                <i class="fas fa-usb"></i> BadUSB Generator
                <span class="nav-badge">HOT</span>
            </div>
            <div class="nav-item" onclick="showSection('botnet')">
                <i class="fas fa-network-wired"></i> Network Stresser
            </div>
            <div class="nav-item" onclick="showSection('encrypt')">
                <i class="fas fa-lock"></i> Encryption Suite
            </div>
            <div class="nav-item" onclick="showSection('bulk')">
                <i class="fas fa-tasks"></i> Bulk Operations
            </div>
        </nav>

        <main class="main-content">
            <!-- Dashboard -->
            <section id="dashboard" class="section">
                <div class="encryption-status">
                    <i class="fas fa-shield-alt"></i>
                    <div>
                        <div style="font-weight: 600; color: var(--neon-green);">End-to-End Encryption Active</div>
                        <div style="font-size: 0.85rem; color: var(--text-dim);">AES-256 | Tor Routing | No Logs</div>
                    </div>
                </div>

                <div class="smart-search">
                    <h2 style="margin-bottom: 15px; color: var(--neon);">
                        <i class="fas fa-magic"></i> Smart Universal Search
                    </h2>
                    <p style="color: var(--text-dim); margin-bottom: 15px;">
                        Enter anything - phone, email, name, address, username, IP, VIN, or domain. Auto-detection enabled.
                    </p>
                    <div class="search-input-wrapper">
                        <input type="text" class="smart-input" id="universalInput" 
                               placeholder="Try: john.doe@email.com, 555-123-4567, 192.168.1.1, @username, 1HGCM82633A004352..."
                               onkeyup="detectInputType(this.value)">
                        <button class="btn btn-primary btn-lg" onclick="universalSearch()">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                    <div id="detectedType"></div>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value" id="statQueries">0</div>
                        <div class="stat-label">Queries Today</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" style="color: var(--neon-green);">94%</div>
                        <div class="stat-label">Success Rate</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" style="color: var(--neon-purple);">15</div>
                        <div class="stat-label">Data Sources</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" style="color: #ff8800;" id="statRecords">0</div>
                        <div class="stat-label">Records Found</div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Global Intelligence Map</span>
                        <span class="status-pill status-online"><span class="pulse-loader"></span> Live</span>
                    </div>
                    <div id="mainMap" class="map-container"></div>
                </div>

                <div class="quick-actions">
                    <div class="quick-action-btn" onclick="quickAction('phone')">
                        <i class="fas fa-phone"></i>
                        <span>Phone Lookup</span>
                    </div>
                    <div class="quick-action-btn" onclick="quickAction('email')">
                        <i class="fas fa-envelope"></i>
                        <span>Email Search</span>
                    </div>
                    <div class="quick-action-btn" onclick="quickAction('person')">
                        <i class="fas fa-user"></i>
                        <span>Person Search</span>
                    </div>
                    <div class="quick-action-btn" onclick="quickAction('address')">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>Address Lookup</span>
                    </div>
                    <div class="quick-action-btn" onclick="quickAction('vehicle')">
                        <i class="fas fa-car"></i>
                        <span>Vehicle Search</span>
                    </div>
                    <div class="quick-action-btn" onclick="quickAction('breach')">
                        <i class="fas fa-shield-alt"></i>
                        <span>Breach Check</span>
                    </div>
                </div>
            </section>

            <!-- Universal Search Results -->
            <section id="universal" class="section hidden">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Universal Search Results</span>
                        <button class="btn btn-secondary btn-sm" onclick="exportResults()">
                            <i class="fas fa-download"></i> Export JSON
                        </button>
                    </div>
                    <div id="universalResults"></div>
                </div>
                
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Geolocation Correlation</span>
                    </div>
                    <div id="universalMap" class="map-container"></div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Associated Profiles</span>
                    </div>
                    <div id="associatedProfiles"></div>
                </div>
            </section>

            <!-- Person Lookup -->
            <section id="person" class="section hidden">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Person Intelligence Database</span>
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px;">
                        <div>
                            <label class="result-label">First Name</label>
                            <input type="text" class="smart-input" id="personFirst" placeholder="John">
                        </div>
                        <div>
                            <label class="result-label">Middle Name</label>
                            <input type="text" class="smart-input" id="personMiddle" placeholder="Optional">
                        </div>
                        <div>
                            <label class="result-label">Last Name</label>
                            <input type="text" class="smart-input" id="personLast" placeholder="Doe">
                        </div>
                    </div>
                    <div style="margin-top: 15px;">
                        <label class="result-label">Location (City, State)</label>
                        <input type="text" class="smart-input" id="personLocation" placeholder="Los Angeles, CA">
                    </div>
                    <div style="margin-top: 15px;">
                        <label class="result-label">Age Range</label>
                        <div style="display: flex; gap: 10px;">
                            <input type="number" class="smart-input" id="ageMin" placeholder="Min" style="flex: 1;">
                            <input type="number" class="smart-input" id="ageMax" placeholder="Max" style="flex: 1;">
                        </div>
                    </div>
                    <div style="margin-top: 15px;">
                        <label class="result-label">Search Parameters</label>
                        <div class="checkbox-grid">
                            <label class="checkbox-item">
                                <input type="checkbox" checked id="searchCriminal"> Criminal Records
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" checked id="searchProperty"> Property Records
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" checked id="searchSocial"> Social Media
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" id="searchBusiness"> Business Filings
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" id="searchVoter"> Voter Registration
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" id="searchCourt"> Court Records
                            </label>
                        </div>
                    </div>
                    <button class="btn btn-primary" style="margin-top: 15px; width: 100%;" onclick="searchPerson()">
                        <i class="fas fa-search"></i> Search Person Records
                    </button>
                </div>
                <div id="personResults"></div>
            </section>

            <!-- Phone Intelligence -->
            <section id="phone" class="section hidden">
                <div class="card">
                    <div class="card-header">
