        div.innerHTML = `<div class="platform-icon">${p.name[0]}</div><div class="platform-name">${p.name}</div>`;
        div.onclick = () => window.open(p.url, '_blank');
        grid.appendChild(div);
      });
      
      // Also search aggregators
      window.open(`https://www.google.com/search?q="${username}"`, '_blank');
      window.open(`https://namechk.com/?q=${username}`, '_blank');
      window.open(`https://knowem.com/checkusernames.php?u=${username}`, '_blank');
      window.open(`https://sherlock-project.github.io/`, '_blank');
    }
    
