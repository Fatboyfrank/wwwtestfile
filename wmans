    function emailPattern() {
      const email = document.getElementById('email-input').value;
      const domain = email.split('@')[1];
      const name = email.split('@')[0];
      
      const patterns = [
        `${name}@${domain}`,
        `${name}1@${domain}`,
        `${name}2@${domain}`,
        `${name}.${name}@${domain}`,
        `${name}_${name}@${domain}`,
        `${name}-${name}@${domain}`,
        `admin@${domain}`,
        `info@${domain}`,
        `support@${domain}`,
        `contact@${domain}`,
        `sales@${domain}`,
        `marketing@${domain}`
      ];
      
      const results = document.getElementById('email-results');
      results.style.display = 'block';
      results.innerHTML = '<div class="result-item"><div class="result-content"><div class="result-title">Generated Patterns:</div><div class="result-meta">' + patterns.join('<br>') + '</div></div></div>';
