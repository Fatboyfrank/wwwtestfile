      const viz = document.getElementById('network-viz');
      viz.innerHTML = '<div style="text-align:center;padding:50px;color:#00ff88;">Building network visualization...</div>';
      
      window.open(`https://www.linkedin.com/search/results/people/?keywords=${seed}`, '_blank');
      window.open(`https://www.facebook.com/search/people/?q=${seed}`, '_blank');
    }
    
    function findConnections() {
      const seed = document.getElementById('network-seed').value;
      window.open(`https://www.google.com/search?q="${seed}"+connections`, '_blank');
    }
    
    function generateTimeline() {
      const target = document.getElementById('timeline-target').value;
      const timeline = document.getElementById('timeline-results');
      
      timeline.innerHTML = `
        <div class="timeline-item">
          <div class="timeline-date">Now</div>
          <div class="timeline-content">Search initiated for: ${target}</div>
          <div class="timeline-source">OSINT Toolkit</div>
        </div>
      `;
      
      window.open(`https://www.google.com/search?q="${target}"&tbm=yrl`, '_blank');
    }
    
    function extractLocations() {
      const target = document.getElementById('geo-target').value;
      
      window.open(`https://www.google.com/maps/search/${target}`, '_blank');
      window.open(`https://www.instagram.com/explore/tags/${target.replace(/ /g, '')}/`, '_blank');
    }
    
    function heatmapMode() {
      map.setStyle('mapbox://styles/mapbox/dark-v10');
      alert('Heatmap mode: Use data overlay tools');
    }
    
    function exifGeolocation() {
      window.open(`https://www.pic2map.com/`, '_blank');
      window.open(`https://www.exifdata.com/`, '_blank');
    }
    
    // ============ ADVANCED TOOLS ============
    
    function bulkSearch() {
      const input = document.getElementById('bulk-input').value;
      const type = document.getElementById('bulk-type').value;
      const items = input.split('\n').filter(i => i.trim());
      
      const results = document.getElementById('bulk-results');
      results.style.display = 'block';
      results.innerHTML = `<div class="result-item"><div class="result-content"><div class="result-title">Processing ${items.length} ${type}...</div></div></div>`;
    }
    
    function saveApis() {
      alert('API keys saved to session storage');
    }
    
    function exportJSON() {
      const data = {
        searches: searchCount,
        found: foundCount,
        markers: markers.length,
        timestamp: new Date().toISOString()
      };
      
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'osint-results.json';
      a.click();
    }
    
    function exportCSV() {
      alert('CSV export: Feature in development');
    }
    
    function exportPDF() {
      window.print();
    }
    
    // ============ MAP FUNCTIONS ============
    
    function geocodeSearch() {
      const query = document.getElementById('map-search').value;
      if (!query) return;
      
      fetch(`https://api.mapbox.com/geocoding/v5/mapbox.places/${encodeURIComponent(query)}.json?access_token=${mapboxgl.accessToken}`)
        .then(r => r.json())
        .then(data => {
          if (data.features && data.features.length > 0) {
            const coords = data.features[0].center;
            map.flyTo({ center: coords, zoom: 16 });
            addMarker({ lng: coords[0], lat: coords[1] }, data.features[0].place_name, 'investigation');
          }
        });
    }
    
    function toggle3D() {
      is3D = !is3D;
      if (is3D) {
        map.setPitch(60);
        map.setBearing(-20);
      } else {
        map.setPitch(0);
        map.setBearing(0);
      }
    }
    
    // Image tools
    function reverseImage() {
      window.open(`https://images.google.com/`, '_blank');
      window.open(`https://tineye.com/`, '_blank');
      window.open(`https://yandex.com/images/`, '_blank');
      window.open(`https://www.bing.com/visualsearch`, '_blank');
    }
    
    function extractExif() {
      window.open(`https://www.exifdata.com/`, '_blank');
      window.open(`https://exif.tools/`, '_blank');
      window.open(`https://www.pic2map.com/`, '_blank');
    }
    
    function faceSearch() {
      window.open(`https://pimeyes.com/`, '_blank');
      window.open(`https://www.faceplusplus.com/`, '_blank');
    }
    
    // Initialize
    updateStats();
  </script>
</body>
</html>
