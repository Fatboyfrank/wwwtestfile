  <script>
    // Initialize Mapbox
    mapboxgl.accessToken = 'pk.eyJ1IjoiZGVtb3VzZXIiLCJhIjoiY2w4Z3F5ZzZqMDFzNTNibnp0b2F3ZzZqciJ9.demo';
    
    const map = new mapboxgl.Map({
      container: 'map',
      style: 'mapbox://styles/mapbox/dark-v10',
      center: [-95.7129, 37.0902],
      zoom: 4,
      pitch: 0,
      bearing: 0
    });
    
    let markers = [];
    let currentHouse = null;
    let is3D = false;
    let searchCount = 0;
    let foundCount = 0;
    
    // Populate states dropdown
    const states = ['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID','IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT','NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC','SD','TN','TX','UT','VT','VA','WA','WV','WI','WY','DC'];
    const stateSelect = document.getElementById('plate-state');
    states.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s;
      opt.textContent = s;
      stateSelect.appendChild(opt);
    });
    
    // Tab switching
    function switchTab(tab) {
      document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      event.target.classList.add('active');
      document.getElementById('tab-' + tab).classList.add('active');
    }
    
    // Update stats
    function updateStats() {
      document.getElementById('stat-searches').textContent = searchCount;
      document.getElementById('stat-found').textContent = foundCount;
      document.getElementById('stat-sources').textContent = markers.length;
      document.getElementById('stat-markers').textContent = markers.length;
    }
    
    // Map click handler - "Click house get info"
    map.on('click', function(e) {
      const features = map.queryRenderedFeatures(e.point, {
        layers: ['building', 'building-3d']
      });
      
      if (features.length > 0) {
        showHouseInfo(e.lngLat, features[0].properties);
      } else {
        // Reverse geocode any click
        reverseGeocode(e.lngLat);
      }
    });
    
    function showHouseInfo(coords, props) {
      currentHouse = { coords, properties: props };
      const popup = document.getElementById('house-popup');
      
      popup.style.display = 'block';
      popup.style.left = (map.project(coords).x + 20) + 'px';
      popup.style.style.top = (map.project(coords).y - 100) + 'px';
      
      document.getElementById('popup-address').textContent = props.address || 'Loading...';
      
      // Fetch detailed property data
      fetchPropertyData(coords);
      
      // Add marker
      addMarker(coords, props.address || 'Property', 'house');
      updateStats();
    }
    
    function closePopup() {
      document.getElementById('house-popup').style.display = 'none';
      currentHouse = null;
    }
    
    function fetchPropertyData(coords) {
      const url = `https://api.mapbox.com/geocoding/v5/mapbox.places/${coords.lng},${coords.lat}.json?access_token=${mapboxgl.accessToken}`;
      
      fetch(url)
        .then(r => r.json())
        .then(data => {
          if (data.features && data.features.length > 0) {
            const address = data.features[0].place_name;
            document.getElementById('popup-address').textContent = address;
            
            // Query multiple property databases
            queryPropertyDatabases(address, coords);
          }
        });
    }
    
    function queryPropertyDatabases(address, coords) {
      document.getElementById('popup-owner').textContent = 'Querying...';
      
      const encoded = encodeURIComponent(address);
      
      // Open property databases in new tabs
      window.open(`https://www.zillow.com/homes/${encoded}_rb/`, '_blank');
      window.open(`https://www.redfin.com/search?query=${encoded}`, '_blank');
      window.open(`https://www.realtor.com/realestateandhomes-search/${encoded}`, '_blank');
      
      // Simulate results (real APIs would go here)
      setTimeout(() => {
        document.getElementById('popup-owner').textContent = 'See Zillow/Redfin';
        document.getElementById('popup-value').textContent = 'Click for details';
        document.getElementById('popup-year').textContent = 'Varies';
        document.getElementById('popup-sqft').textContent = 'Varies';
        document.getElementById('popup-beds').textContent = 'Varies';
        document.getElementById('popup-baths').textContent = 'Varies';
        document.getElementById('popup-sale').textContent = 'Varies';
        document.getElementById('popup-taxes').textContent = 'Varies';
      }, 1500);
    }
    
    function deepPropertySearch() {
      if (!currentHouse) return;
      const address = encodeURIComponent(document.getElementById('popup-address').textContent);
      
      window.open(`https://www.propertyshark.com/search/?search=${address}`, '_blank');
      window.open(`https://www.countyrecords.com/search/?q=${address}`, '_blank');
      window.open(`https://www.loopnet.com/search/commercial-real-estate/${address}`, '_blank');
    }
    
    function reverseGeocode(lngLat) {
      const url = `https://api.mapbox.com/geocoding/v5/mapbox.places/${lngLat.lng},${lngLat.lat}.json?access_token=${mapboxgl.accessToken}`;
      
      fetch(url)
        .then(r => r.json())
        .then(data => {
          if (data.features && data.features.length > 0) {
            addMarker(lngLat, data.features[0].place_name, 'investigation');
          }
        });
    }
    
    function addMarker(coords, title, type) {
      const el = document.createElement('div');
      el.className = `marker marker-${type}`;
      el.style.cssText = `width:30px;height:30px;border-radius:50%;border:3px solid #fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 0 15px rgba(0,0,0,0.5);`;
      
      // Color based on type
      const colors = {
        house: '#00ff88',
        investigation: '#0088ff',
        camera: '#ff4444',
        email: '#aa00ff',
        license: '#ffaa00'
      };
      el.style.background = colors[type] || '#0088ff';
      
      const marker = new mapboxgl.Marker(el)
        .setLngLat(coords)
        .addTo(map);
      
      marker.getElement().addEventListener('click', () => {
        if (type === 'house') showHouseInfo(coords, { address: title });
      });
      
      markers.push(marker);
      updateStats();
      return marker;
    }
    
    function clearMarkers() {
      markers.forEach(m => m.remove());
      markers = [];
      updateStats();
    }
    
    // ============ PERSON TOOLS ============
    
    function searchPerson() {
      const name = document.getElementById('person-name').value;
      const location = document.getElementById('person-location').value;
      if (!name) return;
      
      searchCount++;
      const query = encodeURIComponent(name + ' ' + location);
      
      const results = document.getElementById('person-results');
      results.style.display = 'block';
      results.innerHTML = '<div style="text-align:center;padding:20px;color:#00ff88;">Searching public records...</div>';
      
      // Open multiple search engines
      window.open(`https://www.google.com/search?q=${query}`, '_blank');
      window.open(`https://www.bing.com/search?q=${query}`, '_blank');
      window.open(`https://www.peekyou.com/${name.replace(/ /g, '_')}`, '_blank');
      window.open(`https://thatsthem.com/search?q=${query}`, '_blank');
      window.open(`https://www.spokeo.com/search?q=${query}`, '_blank');
      window.open(`https://www.whitepages.com/name/${name.replace(/ /g, '-')}`, '_blank');
      
      setTimeout(() => {
        results.innerHTML = `
          <div class="result-item">
            <div class="result-icon found">✓</div>
            <div class="result-content">
              <div class="result-title">Search Initiated</div>
              <div class="result-meta">Results opened in new tabs</div>
            </div>
          </div>
        `;
        foundCount++;
        updateStats();
      }, 1000);
    }
    
    function searchVoter() {
      const name = document.getElementById('person-name').value;
      window.open(`https://voterrecords.com/voters/${name.replace(/ /g, '+')}`, '_blank');
    }
    
    function searchUsername() {
      const username = document.getElementById('username-input').value;
      if (!username) return;
      
      searchCount++;
      
      const platforms = [
        { name: 'Instagram', url: `https://www.instagram.com/${username}/` },
        { name: 'Twitter', url: `https://twitter.com/${username}` },
        { name: 'Facebook', url: `https://www.facebook.com/${username}` },
        { name: 'TikTok', url: `https://www.tiktok.com/@${username}` },
