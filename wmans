    function analyzeEmail() {
      const email = document.getElementById('email-input').value;
      if (!email.includes('@')) return;
      
      searchCount++;
      
      const domain = email.split('@')[1];
      const results = document.getElementById('email-results');
      results.style.display = 'block';
      results.innerHTML = `<div class="result-item"><div class="result-icon found">@</div><div class="result-content"><div class="result-title">Domain: ${domain}</div><div class="result-meta">Analyzing...</div></div></div>`;
      
      window.open(`https://www.google.com/search?q="${email}"`, '_blank');
