<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OSINT GEOINT Pro - Free API Edition</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root { 
            --neon: #00f0ff; 
            --neon-purple: #b026ff; 
            --neon-green: #00ff88;
            --bg: #0a0a0f; 
            --card: #12121a; 
            --border: #2a2a3a; 
        }
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background: var(--bg); 
            color: #e0e0e0; 
            min-height: 100vh;
        }
        .sidebar {
            width: 300px;
            background: var(--card);
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            border-right: 1px solid var(--border);
            z-index: 1000;
        }
        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid var(--border);
        }
        .sidebar-header h1 {
            color: var(--neon);
            font-size: 1.5rem;
            text-shadow: 0 0 10px var(--neon);
        }
        .nav-item {
            padding: 15px 20px;
            cursor: pointer;
            border-left: 3px solid transparent;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .nav-item:hover, .nav-item.active {
            background: rgba(0, 240, 255, 0.1);
            border-left-color: var(--neon);
            color: var(--neon);
        }
        .nav-item i { width: 20px; }
        .main-content { margin-left: 300px; padding: 20px; }
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }
        .card-title { font-size: 1.2rem; color: #fff; }
        .input-group { margin-bottom: 16px; }
        .input-label {
            display: block;
            margin-bottom: 6px;
            color: #888;
            font-size: 0.85rem;
            text-transform: uppercase;
        }
        .input-field {
            width: 100%;
            padding: 12px 16px;
            background: #1a1a25;
            border: 1px solid var(--border);
            border-radius: 8px;
            color: #fff;
            font-size: 0.95rem;
        }
        .input-field:focus {
            outline: none;
            border-color: var(--neon);
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.2);
        }
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--neon), var(--neon-purple));
            color: #000;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0, 240, 255, 0.4);
        }
        .btn-secondary {
            background: var(--border);
            color: #fff;
        }
        .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
        #map { height: 500px; border-radius: 8px; }
        .result-box {
            background: #1a1a25;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 16px;
            margin-top: 12px;
            font-family: monospace;
            font-size: 0.85rem;
            max-height: 400px;
            overflow-y: auto;
        }
        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .status-active { background: rgba(0, 255, 136, 0.2); color: var(--neon-green); }
        .status-error { background: rgba(255, 68, 68, 0.2); color: #ff4444; }
        .hidden { display: none !important; }
        .tab-container {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 12px;
        }
        .tab {
            padding: 8px 16px;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: #888;
            cursor: pointer;
        }
        .tab.active {
            background: var(--neon);
            color: #000;
            border-color: var(--neon);
        }
        .stat-card {
            background: linear-gradient(135deg, rgba(0, 240, 255, 0.1), rgba(176, 38, 255, 0.1));
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }
        .stat-value { font-size: 2rem; font-weight: 700; color: var(--neon); }
        .stat-label { color: #888; font-size: 0.85rem; }
        .loader {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid var(--border);
            border-top-color: var(--neon);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .section { display: none; }
        .section.active { display: block; }
        .checkbox-group {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 12px;
        }
        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            background: #1a1a25;
            border-radius: 6px;
            cursor: pointer;
        }
        .timeline {
            position: relative;
            padding-left: 30px;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 8px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: var(--neon);
        }
        .timeline-item {
            position: relative;
            margin-bottom: 20px;
            padding: 16px;
            background: #1a1a25;
            border-radius: 8px;
            border-left: 3px solid var(--neon);
        }
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -26px;
            top: 20px;
            width: 12px;
            height: 12px;
            background: var(--neon);
            border-radius: 50%;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }
        th {
            background: #1a1a25;
            color: var(--neon);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
        }
        .geolocation-point {
            padding: 12px;
            background: #1a1a25;
            border-radius: 8px;
            margin-bottom: 8px;
            border-left: 3px solid var(--neon-green);
        }
        .coords { font-family: monospace; color: var(--neon-green); }
        .breach-item {
            padding: 12px;
            background: #1a1a25;
            border-radius: 8px;
            margin-bottom: 8px;
            border-left: 3px solid #ff4444;
        }
        .property-card {
            padding: 16px;
            background: #1a1a25;
            border-radius: 8px;
            margin-bottom: 12px;
        }
        .modal {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
        }
        .modal.show { display: flex; }
        .modal-content {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            max-width: 600px;
            width: 90%;
        }
        .progress-bar {
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--neon), var(--neon-purple));
            transition: width 0.3s;
        }
        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            padding: 16px 24px;
            background: var(--card);
            border: 1px solid var(--neon);
            border-radius: 8px;
            color: #fff;
            z-index: 10000;
            transform: translateX(400px);
            transition: transform 0.3s;
        }
        .toast.show { transform: translateX(0); }
        .network-graph { height: 500px; background: #0a0a0f; border-radius: 8px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <h1><i class="fas fa-satellite-dish"></i> OSINT GEOINT</h1>
            <p style="color: #888; font-size: 0.75rem;">Free API Edition v3.0</p>
        </div>
        <nav>
            <div class="nav-item active" onclick="showSection('dashboard')">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </div>
            <div class="nav-item" onclick="showSection('ipintel')">
                <i class="fas fa-network-wired"></i> IP Geolocation
            </div>
            <div class="nav-item" onclick="showSection('wifi')">
                <i class="fas fa-wifi"></i> WiFi/BSSID Mapping
            </div>
            <div class="nav-item" onclick="showSection('cell')">
                <i class="fas fa-broadcast-tower"></i> Cell Tower Triangulation
            </div>
            <div class="nav-item" onclick="showSection('address')">
                <i class="fas fa-map-marker-alt"></i> Address Intelligence
            </div>
            <div class="nav-item" onclick="showSection('property')">
                <i class="fas fa-home"></i> Property Records
            </div>
            <div class="nav-item" onclick="showSection('social')">
                <i class="fas fa-users"></i> Social Media GEOINT
            </div>
            <div class="nav-item" onclick="showSection('vehicle')">
                <i class="fas fa-car"></i> Vehicle Tracking
            </div>
            <div class="nav-item" onclick="showSection('financial')">
                <i class="fas fa-dollar-sign"></i> Financial GEOINT
            </div>
            <div class="nav-item" onclick="showSection('digital')">
                <i class="fas fa-fingerprint"></i> Digital Footprint
            </div>
            <div class="nav-item" onclick="showSection('public')">
                <i class="fas fa-folder-open"></i> Public Records
            </div>
            <div class="nav-item" onclick="showSection('business')">
                <i class="fas fa-building"></i> Business Intelligence
            </div>
            <div class="nav-item" onclick="showSection('telecom')">
                <i class="fas fa-phone"></i> Telecommunications
            </div>
            <div class="nav-item" onclick="showSection('darkweb')">
                <i class="fas fa-user-secret"></i> Dark Web & Breaches
            </div>
            <div class="nav-item" onclick="showSection('visual')">
                <i class="fas fa-eye"></i> Visual Reconnaissance
            </div>
            <div class="nav-item" onclick="showSection('behavioral')">
                <i class="fas fa-brain"></i> Behavioral Analysis
            </div>
            <div class="nav-item" onclick="showSection('bulk')">
                <i class="fas fa-tasks"></i> Bulk Operations
            </div>
        </nav>
    </div>

    <div class="main-content">
        <!-- Dashboard -->
        <div id="dashboard" class="section active">
            <h2 style="margin-bottom: 20px;">OSINT Intelligence Dashboard</h2>
            <div class="grid-4">
                <div class="stat-card">
                    <div class="stat-value" id="totalQueries">0</div>
                    <div class="stat-label">Total Queries</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="activeSources">15</div>
                    <div class="stat-label">Active Sources</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="dataPoints">0</div>
                    <div class="stat-label">Data Points</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="successRate">94%</div>
                    <div class="stat-label">Success Rate</div>
                </div>
            </div>
            
            <div class="card" style="margin-top: 20px;">
                <div class="card-header">
                    <span class="card-title">Global Intelligence Map</span>
                    <button class="btn btn-secondary" onclick="locateMe()">
                        <i class="fas fa-crosshairs"></i> My Location
                    </button>
                </div>
                <div id="mainMap"></div>
            </div>

            <div class="grid-2" style="margin-top: 20px;">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">API Status</span>
                    </div>
                    <div id="apiStatus">
                        <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border);">
                            <span>ip-api.com</span>
                            <span class="status-badge status-active">Active</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border);">
                            <span>OpenStreetMap</span>
                            <span class="status-badge status-active">Active</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border);">
                            <span>Overpass API</span>
                            <span class="status-badge status-active">Active</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 10px 0;">
                            <span>Nominatim</span>
                            <span class="status-badge status-active">Active</span>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Quick Search</span>
                    </div>
                    <div class="input-group">
                        <input type="text" class="input-field" id="quickSearch" placeholder="IP, Address, Phone, Email...">
                    </div>
                    <button class="btn btn-primary w-full" onclick="quickSearch()">
                        <i class="fas fa-search"></i> Search All Sources
                    </button>
                </div>
            </div>
        </div>

        <!-- IP Geolocation -->
        <div id="ipintel" class="section">
            <h2 style="margin-bottom: 20px;">IP Geolocation Intelligence</h2>
            <div class="grid-2">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Single IP Lookup</span>
                    </div>
                    <div class="input-group">
                        <label class="input-label">IP Address</label>
                        <input type="text" class="input-field" id="ipAddress" placeholder="192.168.1.1 or 8.8.8.8">
                    </div>
                    <div class="input-group">
                        <label class="input-label">
                            <input type="checkbox" id="vpnCheck"> Include VPN/Proxy Detection
                        </label>
                    </div>
                    <button class="btn btn-primary w-full" onclick="lookupIP()">
                        <i class="fas fa-search"></i> Geolocate IP
                    </button>
                    <div id="ipResult" class="result-box hidden"></div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Bulk IP Analysis</span>
                    </div>
                    <div class="input-group">
                        <label class="input-label">IP Addresses (one per line)</label>
                        <textarea class="input-field" id="bulkIPs" rows="5" placeholder="8.8.8.8&#10;1.1.1.1"></textarea>
                    </div>
                    <button class="btn btn-primary w-full" onclick="bulkIPLookup()">
                        <i class="fas fa-list"></i> Process Batch
                    </button>
                </div>
            </div>
            <div class="card" style="margin-top: 20px;">
                <div class="card-header">
                    <span class="card-title">IP Location Map</span>
                </div>
                <div id="ipMap"></div>
            </div>
        </div>

        <!-- WiFi/BSSID -->
        <div id="wifi" class="section">
            <h2 style="margin-bottom: 20px;">WiFi Network & BSSID Intelligence</h2>
            <div class="grid-2">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">BSSID Geolocation</span>
                    </div>
                    <div class="input-group">
                        <label class="input-label">BSSID/MAC Address</label>
                        <input type="text" class="input-field" id="bssidInput" placeholder="AA:BB:CC:DD:EE:FF">
                    </div>
                    <div class="input-group">
                        <label class="input-label">SSID (Network Name)</label>
                        <input type="text" class="input-field" id="ssidInput" placeholder="NETGEAR-5G">
                    </div>
                    <button class="btn btn-primary w-full" onclick="lookupBSSID()">
                        <i class="fas fa-wifi"></i> Locate WiFi Network
                    </button>
                    <div id="wifiResult" class="result-box hidden"></div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Wardriving Database Search</span>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Search Area (Coordinates)</label>
                        <input type="text" class="input-field" id="wifiArea" placeholder="34.0522,-118.2437">
                    </div>
                    <div class="input-group">
                        <label class="input-label">Radius (meters)</label>
                        <input type="number" class="input-field" id="wifiRadius" value="1000">
                    </div>
                    <button class="btn btn-primary w-full" onclick="searchWigle()">
                        <i class="fas fa-database"></i> Query Wardriving DB
                    </button>
                </div>
            </div>
            <div class="card" style="margin-top: 20px;">
                <div class="card-header">
                    <span class="card-title">WiFi Network Map</span>
                </div>
                <div id="wifiMap"></div>
            </div>
        </div>

        <!-- Cell Tower -->
        <div id="cell" class="section">
            <h2 style="margin-bottom: 20px;">Cell Tower Triangulation</h2>
            <div class="grid-3">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Cell ID Lookup</span>
                    </div>
                    <div class="input-group">
                        <label class="input-label">MCC (Mobile Country Code)</label>
                        <input type="text" class="input-field" id="mcc" placeholder="310">
                    </div>
                    <div class="input-group">
                        <label class="input-label">MNC (Mobile Network Code)</label>
                        <input type="text" class="input-field" id="mnc" placeholder="260">
                    </div>
                    <div class="input-group">
                        <label class="input-label">LAC/TAC</label>
                        <input type="text" class="input-field" id="lac" placeholder="12345">
                    </div>
                    <div class="input-group">
                        <label class="input-label">Cell ID</label>
                        <input type="text" class="input-field" id="cellId" placeholder="67890">
                    </div>
                    <button class="btn btn-primary w-full" onclick="lookupCell()">
                        <i class="fas fa-broadcast-tower"></i> Locate Cell Tower
                    </button>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Signal Analysis</span>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Signal Strength (dBm)</label>
                        <input type="number" class="input-field" id="signalDbm" placeholder="-85">
                    </div>
                    <div class="input-group">
                        <label class="input-label">Timing Advance</label>
                        <input type="number" class="input-field" id="timingAdvance" placeholder="5">
                    </div>
                    <div class="input-group">
                        <label class="input-label">Network Type</label>
                        <select class="input-field" id="networkType">
                            <option value="4G">4G LTE</option>
                            <option value="5G">5G NR</option>
                            <option value="3G">3G UMTS</option>
                            <option value="2G">2G GSM</option>
                        </select>
                    </div>
                    <button class="btn btn-secondary w-full" onclick="estimateRange()">
                        <i class="fas fa-ruler"></i> Estimate Range
                    </button>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Tower Database</span>
                    </div>
                    <div id="cellResults">
                        <p style="color: #888; text-align: center; padding: 20px;">Enter cell parameters to search</p>
                    </div>
                </div>
            </div>
            <div class="card" style="margin-top: 20px;">
                <div class="card-header">
                    <span class="card-title">Cell Tower Coverage Map</span>
                </div>
                <div id="cellMap"></div>
            </div>
        </div>

        <!-- Address Intelligence -->
        <div id="address" class="section">
            <h2 style="margin-bottom: 20px;">Address & Geocoding Intelligence</h2>
            <div class="grid-2">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Forward Geocoding</span>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Street Address</label>
                        <input type="text" class="input-field" id="fwdAddress" placeholder="1600 Pennsylvania Avenue NW">
                    </div>
                    <div class="input-group">
                        <label class="input-label">City</label>
                        <input type="text" class="input-field" id="fwdCity" placeholder="Washington">
                    </div>
                    <div class="grid-2">
                        <div class="input-group">
                            <label class="input-label">State</label>
                            <input type="text" class="input-field" id="fwdState" placeholder="DC">
                        </div>
                        <div class="input-group">
                            <label class="input-label">ZIP</label>
                            <input type="text" class="input-field" id="fwdZip" placeholder="20500">
                        </div>
                    </div>
                    <button class="btn btn-primary w-full" onclick="forwardGeocode()">
                        <i class="fas fa-map-marker-alt"></i> Geocode Address
                    </button>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Reverse Geocoding</span>
                    </div>
                    <div class="grid-2">
                        <div class="input-group">
                            <label class="input-label">Latitude</label>
                            <input type="text" class="input-field" id="revLat" placeholder="38.8977">
                        </div>
                        <div class="input-group">
                            <label class="input-label">Longitude</label>
                            <input type="text" class="input-field" id="revLng" placeholder="-77.0365">
                        </div>
                    </div>
                    <button class="btn btn-primary w-full" onclick="reverseGeocode()">
                        <i class="fas fa-home"></i> Reverse Geocode
                    </button>
                    <div id="geocodeResult" class="result-box hidden"></div>
                </div>
            </div>
            <div class="card" style="margin-top: 20px;">
                <div class="card-header">
                    <span class="card-title">Address Validation & History</span>
                </div>
                <div class="grid-2">
                    <div class="input-group">
                        <label class="input-label">Validate Address</label>
                        <input type="text" class="input-field" id="validateAddress" placeholder="Enter full address">
                    </div>
                    <div class="input-group">
                        <label class="input-label">Search Historical Data</label>
                        <input type="text" class="input-field" id="histAddress" placeholder="Previous residents, sale dates...">
                    </div>
                </div>
                <button class="btn btn-primary" onclick="validateAddress()">
                    <i class="fas fa-check"></i> Validate
                </button>
                <button class="btn btn-secondary" onclick="searchHistory()">
                    <i class="fas fa-history"></i> History
                </button>
            </div>
            <div id="addressMap" style="height: 400px; margin-top: 20px; border-radius: 8px;"></div>
        </div>

        <!-- Property Records -->
        <div id="property" class="section">
