        // IP Geolocation
        async function lookupIP() {
            const ip = document.getElementById('ipAddress').value;
            if (!ip) return showToast('Enter IP address', 'error');
            
            const resultDiv = document.getElementById('ipResult');
            resultDiv.classList.remove('hidden');
            resultDiv.innerHTML = '<div class="loader"></div> Querying...';
            
            try {
                // Using free ip-api.com (no key required)
                const response = await fetch(`http://ip-api.com/json/${ip}?fields=status,message,country,countryCode,region,regionName,city,zip,lat,lon,timezone,isp,org,as,mobile,proxy,hosting`);
                const data = await response.json();
                
                if (data.status === 'success') {
                    resultDiv.innerHTML = `
                        <div style="display: grid; gap: 10px;">
                            <div><strong>IP:</strong> ${ip}</div>
                            <div><strong>Country:</strong> ${data.country} (${data.countryCode})</div>
                            <div><strong>Region:</strong> ${data.regionName}</div>
                            <div><strong>City:</strong> ${data.city}</div>
                            <div><strong>ZIP:</strong> ${data.zip}</div>
                            <div><strong>Coords:</strong> <span class="coords">${data.lat}, ${data.lon}</span></div>
                            <div><strong>ISP:</strong> ${data.isp}</div>
                            <div><strong>Organization:</strong> ${data.org}</div>
                            <div><strong>AS:</strong> ${data.as}</div>
                            <div><strong>Timezone:</strong> ${data.timezone}</div>
                            <div><strong>Mobile:</strong> ${data.mobile ? 'Yes' : 'No'}</div>
                            <div><strong>Proxy/VPN:</strong> ${data.proxy ? 'Yes' : 'No'}</div>
                            <div><strong>Hosting:</strong> ${data.hosting ? 'Yes' : 'No'}</div>
                        </div>
                    `;
                    
                    // Add to map
                    const map = initMap('ipMap');
                    L.marker([data.lat, data.lon]).addTo(map)
                        .bindPopup(`<b>${ip}</b><br>${data.city}, ${data.country}`)
                        .openPopup();
                    map.setView([data.lat, data.lon], 13);
                    
                    showToast('IP geolocation complete', 'success');
                } else {
                    resultDiv.innerHTML = `<div class="text-red-400">Error: ${data.message}</div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = `<div class="text-red-400">Error: ${error.message}</div>`;
            }
        }

