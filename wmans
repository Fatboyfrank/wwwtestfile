<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OSINT MASTER PRO - Skid Dashboard v3.0</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0a0a0f;
            --bg-secondary: #12121a;
            --bg-card: #1a1a24;
            --bg-hover: #252532;
            --bg-tertiary: #0d0d12;
            --accent-primary: #00ff88;
            --accent-danger: #ff4444;
            --accent-warning: #ffaa00;
            --accent-info: #00aaff;
            --accent-purple: #aa00ff;
            --accent-pink: #ff00aa;
            --text-primary: #ffffff;
            --text-secondary: #a0a0b0;
            --border-color: #2a2a3a;
            --glow-primary: 0 0 20px rgba(0, 255, 136, 0.3);
            --glow-danger: 0 0 20px rgba(255, 68, 68, 0.3);
            --glow-info: 0 0 20px rgba(0, 170, 255, 0.3);
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Animated Background */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .bg-animation::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: 
                radial-gradient(circle at 20% 80%, rgba(0, 255, 136, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255, 68, 68, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 40% 40%, rgba(170, 0, 255, 0.02) 0%, transparent 40%);
            animation: bgPulse 15s ease-in-out infinite;
        }

        @keyframes bgPulse {
            0%, 100% { transform: scale(1) rotate(0deg); }
            50% { transform: scale(1.1) rotate(5deg); }
        }

        /* Matrix Rain Effect */
        .matrix-rain {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
            opacity: 0.04;
        }

        .matrix-column {
            position: absolute;
            top: -100%;
            color: var(--accent-primary);
            font-family: monospace;
            font-size: 14px;
            animation: matrixFall linear infinite;
            white-space: nowrap;
        }

        @keyframes matrixFall {
            to { transform: translateY(200vh); }
        }

        /* Main Container */
        .dashboard-container {
            position: relative;
            z-index: 2;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 300px;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            z-index: 100;
        }

        .sidebar-header {
            padding: 25px;
            border-bottom: 1px solid var(--border-color);
            text-align: center;
        }

        .logo {
            font-size: 1.6rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-info));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .logo i {
            font-size: 1.8rem;
        }

        .version {
            font-size: 0.7rem;
            color: var(--text-secondary);
            margin-top: 5px;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .nav-section {
            padding: 15px;
        }

        .nav-title {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-secondary);
            margin-bottom: 10px;
            padding-left: 10px;
            font-weight: 700;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            margin-bottom: 5px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: var(--text-secondary);
            font-size: 0.9rem;
            position: relative;
        }

        .nav-item:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

        .nav-item.active {
            background: linear-gradient(135deg, rgba(0, 255, 136, 0.1), rgba(0, 170, 255, 0.1));
            color: var(--accent-primary);
            border: 1px solid rgba(0, 255, 136, 0.3);
        }

        .nav-item i {
            width: 20px;
            text-align: center;
        }

        .nav-badge {
            margin-left: auto;
            background: var(--accent-danger);
            color: white;
            font-size: 0.65rem;
            padding: 2px 8px;
            border-radius: 10px;
            font-weight: 700;
        }

        .nav-item.active .nav-badge {
            background: var(--accent-primary);
            color: var(--bg-primary);
        }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 300px;
            padding: 25px;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .header-title {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .header-title span {
            color: var(--accent-primary);
        }

        .header-actions {
            display: flex;
            gap: 15px;
        }

        .header-btn {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }

        .header-btn:hover {
            background: var(--bg-hover);
            border-color: var(--accent-primary);
        }

        /* Stats Bar */
        .stats-bar {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .stat-icon.green { background: rgba(0, 255, 136, 0.1); color: var(--accent-primary); }
        .stat-icon.red { background: rgba(255, 68, 68, 0.1); color: var(--accent-danger); }
        .stat-icon.blue { background: rgba(0, 170, 255, 0.1); color: var(--accent-info); }
        .stat-icon.purple { background: rgba(170, 0, 255, 0.1); color: var(--accent-purple); }

        .stat-info h4 {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-value {
            font-size: 1.8rem;
            font-weight: 700;
        }

        /* Tool Grid */
        .tools-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
            gap: 20px;
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .card:hover {
            border-color: var(--accent-primary);
            box-shadow: var(--glow-primary);
            transform: translateY(-2px);
        }

        .card.danger:hover {
            border-color: var(--accent-danger);
            box-shadow: var(--glow-danger);
        }

        .card-header {
            padding: 15px 20px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-title {
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.95rem;
        }

        .card-title i {
            color: var(--accent-primary);
            font-size: 1.1rem;
        }

        .card.danger .card-title i {
            color: var(--accent-danger);
        }

        .card.warning .card-title i {
            color: var(--accent-warning);
        }

        .card.info .card-title i {
            color: var(--accent-info);
        }

        .status-pill {
            font-size: 0.65rem;
            padding: 4px 10px;
            border-radius: 20px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .status-online {
            background: rgba(0, 255, 136, 0.15);
            color: var(--accent-primary);
        }

        .status-offline {
            background: rgba(255, 68, 68, 0.15);
            color: var(--accent-danger);
        }

        .status-busy {
            background: rgba(255, 170, 0, 0.15);
            color: var(--accent-warning);
        }

        .status-info {
            background: rgba(0, 170, 255, 0.15);
            color: var(--accent-info);
        }

        .card-body {
            padding: 20px;
        }

        /* Form Elements */
        .smart-input {
            width: 100%;
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 12px 15px;
            border-radius: 8px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        .smart-input:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 10px rgba(0, 255, 136, 0.2);
        }

        .smart-input::placeholder {
            color: var(--text-secondary);
        }

        textarea.smart-input {
            resize: vertical;
            min-height: 80px;
            font-family: monospace;
        }

        select.smart-input {
            cursor: pointer;
        }

        .input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
        }

        .input-group .smart-input {
            flex: 1;
        }

        /* Buttons */
        .btn {
            background: var(--bg-hover);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 12px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-info));
            border: none;
            color: var(--bg-primary);
        }

        .btn-danger {
            background: linear-gradient(135deg, var(--accent-danger), #ff6666);
            border: none;
            color: white;
        }

        .btn-warning {
            background: linear-gradient(135deg, var(--accent-warning), #ffcc00);
            border: none;
            color: var(--bg-primary);
        }

        .btn-secondary {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
        }

        .btn-secondary:hover {
            border-color: var(--accent-primary);
            color: var(--accent-primary);
        }

        .btn-lg {
            padding: 15px 30px;
            font-size: 1.1rem;
        }

        .btn-sm {
            padding: 8px 15px;
            font-size: 0.8rem;
        }

        .btn-block {
            width: 100%;
        }

        /* Checkbox Grid */
        .checkbox-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin: 15px 0;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .checkbox-item input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--accent-primary);
        }

        /* Tabs */
        .tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 15px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px;
        }

        .tab {
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.85rem;
            color: var(--text-secondary);
            transition: all 0.3s ease;
        }

        .tab:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

        .tab.active {
            background: var(--accent-primary);
            color: var(--bg-primary);
            font-weight: 600;
        }

        /* Terminal Output */
        .terminal-output {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 15px;
            font-family: 'Courier New', monospace;
            font-size: 0.8rem;
            max-height: 200px;
            overflow-y: auto;
            line-height: 1.6;
        }

        .terminal-line {
            margin-bottom: 5px;
        }

        .terminal-line.success { color: var(--accent-primary); }
        .terminal-line.error { color: var(--accent-danger); }
        .terminal-line.info { color: var(--accent-info); }
        .terminal-line.warning { color: var(--accent-warning); }

        /* Progress Bar */
        .progress-container {
            background: var(--bg-secondary);
            border-radius: 10px;
            height: 8px;
            overflow: hidden;
            margin: 15px 0;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-info));
            border-radius: 10px;
            transition: width 0.3s ease;
        }

        .progress-bar.danger {
            background: linear-gradient(90deg, var(--accent-danger), #ff6666);
        }

        /* Output Box */
        .output-box {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 15px;
            margin-top: 15px;
            min-height: 100px;
            max-height: 300px;
            overflow-y: auto;
            font-family: monospace;
            font-size: 0.85rem;
        }

        .output-line {
            padding: 3px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Attack Methods Grid */
        .attack-methods {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin: 15px 0;
        }

        .method-btn {
            padding: 15px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            cursor: pointer;
            text-align: center;
            transition: all 0.3s ease;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .method-btn:hover, .method-btn.active {
            border-color: var(--accent-danger);
            background: rgba(255, 68, 68, 0.1);
            color: var(--accent-danger);
        }

        /* Config Grid */
        .config-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }

        .config-item {
            background: var(--bg-secondary);
            padding: 15px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
        }

        .config-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .config-value {
            font-size: 1.2rem;
            font-weight: 700;
        }

        /* Tool Specific Styles */
        .nitro-codes {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
            margin-top: 10px;
            max-height: 200px;
            overflow-y: auto;
        }

        .nitro-code {
            background: var(--bg-secondary);
            padding: 10px;
            border-radius: 6px;
            font-family: monospace;
            font-size: 0.75rem;
            text-align: center;
            border: 1px solid var(--border-color);
            word-break: break-all;
        }

        .nitro-code.valid {
            border-color: var(--accent-primary);
            color: var(--accent-primary);
        }

        .nitro-code.invalid {
            border-color: var(--accent-danger);
            color: var(--accent-danger);
            text-decoration: line-through;
        }

        .account-list {
            max-height: 200px;
            overflow-y: auto;
        }

        .account-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            background: var(--bg-secondary);
            border-radius: 6px;
            margin-bottom: 8px;
            border: 1px solid var(--border-color);
        }

        .account-item.valid {
            border-color: var(--accent-primary);
        }

        .account-item.invalid {
            border-color: var(--accent-danger);
            opacity: 0.6;
        }

        .skid-level {
            font-size: 0.65rem;
            padding: 3px 8px;
            border-radius: 4px;
            text-transform: uppercase;
            font-weight: 700;
        }

        .level-noob { background: #444; color: #aaa; }
        .level-beginner { background: #2a4a2a; color: var(--accent-primary); }
        .level-skid { background: #4a2a2a; color: var(--accent-danger); }

        /* Quick Actions */
        .quick-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .quick-action-btn {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 8px 15px;
            border-radius: 6px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .quick-action-btn:hover {
            border-color: var(--accent-primary);
            color: var(--accent-primary);
        }

        /* Range Slider */
        input[type="range"] {
            width: 100%;
            height: 6px;
            background: var(--bg-secondary);
            border-radius: 3px;
            outline: none;
            -webkit-appearance: none;
            margin-top: 8px;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            background: var(--accent-primary);
            border-radius: 50%;
            cursor: pointer;
        }

        /* Results Table */
        .results-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            font-size: 0.85rem;
        }

        .results-table th,
        .results-table td {
            padding: 10px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .results-table th {
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
        }

        .results-table tr:hover {
            background: var(--bg-hover);
        }

        /* Tag/Badge */
        .tag {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .tag-success { background: rgba(0, 255, 136, 0.2); color: var(--accent-primary); }
        .tag-danger { background: rgba(255, 68, 68, 0.2); color: var(--accent-danger); }
        .tag-warning { background: rgba(255, 170, 0, 0.2); color: var(--accent-warning); }
        .tag-info { background: rgba(0, 170, 255, 0.2); color: var(--accent-info); }

        /* Hidden sections */
        .tool-section {
            display: none;
        }

        .tool-section.active {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Notification */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 15px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 1000;
            transform: translateX(400px);
            transition: transform 0.3s ease;
            max-width: 350px;
        }

        .notification.show {
            transform: translateX(0);
        }

        .notification.success {
            border-color: var(--accent-primary);
        }

        .notification.error {
            border-color: var(--accent-danger);
        }

        .notification.warning {
            border-color: var(--accent-warning);
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-secondary);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--accent-primary);
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
        }

        @media (max-width: 768px) {
            .stats-bar {
                grid-template-columns: repeat(2, 1fr);
            }
            .tools-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Loading Spinner */
        .spinner {
            width: 20px;
            height: 20px;
            border: 2px solid transparent;
            border-top-color: currentColor;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Full width cards */
        .card-full {
            grid-column: 1 / -1;
        }

        /* Tool list view */
        .tool-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .tool-list-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .tool-list-item:hover {
            border-color: var(--accent-primary);
            background: var(--bg-hover);
        }

        .tool-list-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
